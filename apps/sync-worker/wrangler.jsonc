{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "drawi-sync-worker",
  "main": "worker/worker.ts",
  "compatibility_date": "2026-06-24",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "DRAWI_BOARD_DURABLE_OBJECT",
        "class_name": "DrawiBoardDurableObject",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["DrawiBoardDurableObject"],
    },
  ],
  "r2_buckets": [
    {
      "binding": "DRAWI_BOARD_BUCKET",
      "bucket_name": "drawi-local-board-assets",
      "preview_bucket_name": "drawi-local-board-assets-preview",
    },
  ],
}

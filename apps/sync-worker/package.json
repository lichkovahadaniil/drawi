{
  "name": "@drawi/sync-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "XDG_CONFIG_HOME=/private/tmp/drawi-xdg-config WRANGLER_CACHE_DIR=/private/tmp/drawi-wrangler-cache WRANGLER_SEND_METRICS=false WRANGLER_SEND_ERROR_REPORTS=false wrangler dev --local --port 8787",
    "build": "XDG_CONFIG_HOME=/private/tmp/drawi-xdg-config WRANGLER_CACHE_DIR=/private/tmp/drawi-wrangler-cache WRANGLER_SEND_METRICS=false WRANGLER_SEND_ERROR_REPORTS=false wrangler deploy --dry-run --outdir dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "types": "wrangler types"
  },
  "dependencies": {
    "cloudflare-workers-unfurl": "^0.0.8",
    "itty-router": "^5.0.18"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251220.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.56.0"
  }
}

APP_URL=https://your-drawi-app.vercel.app

DATABASE_URL=postgresql://user:password@host.neon.tech/drawi?sslmode=require

BETTER_AUTH_SECRET=replace-with-a-32-byte-production-secret
BETTER_AUTH_URL=https://your-drawi-app.vercel.app

NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret

NEXT_PUBLIC_DRAWI_SYNC_URL=https://drawi-sync-worker.your-cloudflare-subdomain.workers.dev
SYNC_COOKIE_SECRET=replace-with-the-same-32-byte-sync-secret-used-by-the-worker
SYNC_WORKER_ORIGIN=https://drawi-sync-worker.your-cloudflare-subdomain.workers.dev
